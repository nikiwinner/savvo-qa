# QA environment variables
# Copy to .env and adjust if needed.
#
# QA runs on dedicated ports so the dev stack on :8000/:5173 can stay up
# indefinitely without contamination of the dev database. Do not change
# these to :8000/:5173 unless you really want to share state with dev.

# Frontend dev server URL (QA-only port)
FRONTEND_URL=http://localhost:5174

# Backend API URL (QA-only port; used by ApiHelper for direct API calls)
BACKEND_URL=http://localhost:8001

# Test database (created automatically if it doesn't exist)
# Uses the same PostgreSQL instance as dev, but a separate database
POSTGRES_DB_NAME=savvo_test
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=password321
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
