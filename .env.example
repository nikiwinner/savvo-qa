# QA environment variables
# Copy to .env and adjust if needed

# Frontend dev server URL
FRONTEND_URL=http://localhost:5173

# Backend API URL (used by ApiHelper for direct API calls)
BACKEND_URL=http://localhost:8000

# Test database (created automatically if it doesn't exist)
# Uses the same PostgreSQL instance as dev, but a separate database
POSTGRES_DB_NAME=ledgerapp_test
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=password321
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
